//------------------------------------------------//--- 010 Editor v16.0.4 Binary Template////      File: Metroid II - Return of Samus (Game Boy) Save Template//   Authors: Hacksy//   Version: 1.0//   Purpose: Parse and edit SRAM save data for Metroid II (GB)//  Category: Game Save// File Mask: *.sav//  ID Bytes: N/A (raw SRAM, no fixed magic)//   History: //     1.0 - Initial template structure and documentation//         //------------------------------------------------LittleEndian();//------------------------------------------------// Helper Functions//------------------------------------------------// Convert BCD → intint BCD_ToInt(ubyte v){    return ((v >> 4) * 10) + (v & 0x0F);}//------------------------------------------------// Types//------------------------------------------------// Clean BCD byte (no raw exposed)typedef struct {    ubyte raw <hidden=true>;} DecimalByte <fgcolor=cGreen,read=BCD_ToInt(this.raw)>;//------------------------------------------------// Slot Structure//------------------------------------------------typedef struct{    byte _unk0[32] <hidden=true>;        DecimalByte HP;        byte _unk1[3] <hidden=true>;        DecimalByte Missiles;    byte _unk <hidden=true>;    byte metroidDestroyed; // 01     byte _unk6[6] <hidden=true>;        DecimalByte remainingMetroids;    byte _unk2[18] <hidden=true>;    } Slot;//------------------------------------------------// Selected Slot//------------------------------------------------typedef struct{    ubyte value <hidden=true>;} CurrentSlot <fgcolor=cDkAqua,read=Str("Slot %d",this.value)>;//------------------------------------------------// Main Save File//------------------------------------------------struct{    Slot Slots[3];        CurrentSlot SelectedSlot;    } MetroidII_Save <name="Metroid II Save">;